{
  "name": "laliga-calendar-ingestion",
  "version": "1.0.0",
  "description": "Weekly ingestion of La Liga team calendars into Supabase",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "ingest": "node -r dotenv/config -e \"require('./src/ingestion/ingest').runIngestion()\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
